# ===== Unity .gitignore =====

# Unity generated
**/[Ll]ibrary/
**/[Tt]emp/
**/[Oo]bj/
**/[Bb]uild/
**/[Bb]uilds/
**/[Ll]ogs/
**/[Uu]ser[Ss]ettings/
**/[Mm]emoryCaptures/
**/[Rr]ecordings/
.utmp/

# Asset imports cache
**/[Aa]ssets/AssetStoreTools*

# Autogenerated IDE files
.vs/
.vscode/
.idea/
*.csproj
*.unityproj
*.sln
*.slnx
*.suo
*.tmp
*.user
*.userprefs
*.pidb
*.booproj
*.svd
*.pdb
*.mdb
*.opendb
*.VC.db
ExportedObj/
.consulo/
*.vsconfig

# Unity meta for generated files
*.pidb.meta
*.pdb.meta
*.mdb.meta

# Crash reports
sysinfo.txt

# Builds
*.apk
*.aab
*.unitypackage
*.unitypackage.meta
*.app
*.exe
*.dll
!**/[Aa]ssets/**/*.dll

# Crashlytics
crashlytics-build.properties

# Packed Addressables
**/[Aa]ssets/[Aa]ddressable[Aa]ssets[Dd]ata/*/*.bin*

# Temporary Android assets
**/[Aa]ssets/[Ss]treamingAssets/aa.meta
**/[Aa]ssets/[Ss]treamingAssets/aa/*

# Jetbrains Rider
**/[Aa]ssets/Plugins/Editor/JetBrains*

# Gradle
.gradle/

# NuGetForUnity
**/[Aa]ssets/Packages/
**/[Aa]ssets/Packages.meta

# OS files
.DS_Store
Thumbs.db
desktop.ini

# Logs
*.log
